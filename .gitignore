# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Sensitive variable files (don't commit secrets)
*.tfvars.secret
secret.tfvars

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Kubernetes secrets (real values — never commit; applied out-of-band)
# secret.example.yaml is intentionally committed (placeholder values only).
k8s/**/secret.yaml
k8s/**/*.secret.yaml
